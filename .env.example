# AI Security System Configuration
# Copy this file to .env and configure your API keys

# VirusTotal API Key (REQUIRED - for IP reputation checks)
# Get your FREE key at: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute
VIRUSTOTAL_API_KEY=

# AbuseIPDB API Key (optional - for community IP blacklist)
# Get your free key at: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# Central Threat Intelligence Server (optional - for global threat sharing)
# Set these to connect to a central server and share/receive threats globally
# Leave empty to run in standalone mode
CENTRAL_SERVER_URL=
CENTRAL_SERVER_API_KEY=
SYNC_ENABLED=false
SYNC_INTERVAL=300  # Sync every 5 minutes

# ExploitDB Configuration
# Path to local ExploitDB database (auto-downloaded during setup)
EXPLOITDB_PATH=/app/AI/exploitdb

# Timezone Configuration
# You can change this in System Settings dashboard
# Examples: Asia/Kuala_Lumpur, Asia/Singapore, Asia/Tokyo, Europe/London, US/Eastern, UTC
TZ=Asia/Kuala_Lumpur

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Security Settings
MAX_BLOCKED_IPS=10000
THREAT_LOG_MAX_SIZE=100000
AUTO_BLOCK_ENABLED=true

# Enterprise API Settings (for companies integrating your system)
ENABLE_ENTERPRISE_API=true
API_RATE_LIMIT=1000

# Learning Mode
AI_LEARNING_ENABLED=true
AUTO_TRAIN_THRESHOLD=5
EXPLOITDB_SCRAPER_ENABLED=true
